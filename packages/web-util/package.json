{
  "name": "@kazura/web-util",
  "version": "2.5.1",
  "description": "web-util",
  "keywords": [
    "util"
  ],
  "homepage": "https://github.com/kazura233/kazurajs/tree/master/packages/web-util#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazura233/kazurajs.git"
  },
  "bugs": "https://github.com/kazura233/kazurajs/issues",
  "author": {
    "name": "kazura233",
    "email": "kazira233@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./save-file": {
      "import": {
        "types": "./dist/save-file/index.d.mts",
        "default": "./dist/save-file/index.mjs"
      },
      "require": {
        "types": "./dist/save-file/index.d.cts",
        "default": "./dist/save-file/index.cjs"
      }
    },
    "./date": {
      "import": {
        "types": "./dist/date/index.d.mts",
        "default": "./dist/date/index.mjs"
      },
      "require": {
        "types": "./dist/date/index.d.cts",
        "default": "./dist/date/index.cjs"
      }
    },
    "./date/local": {
      "import": {
        "types": "./dist/date/local.d.mts",
        "default": "./dist/date/local.mjs"
      },
      "require": {
        "types": "./dist/date/local.d.cts",
        "default": "./dist/date/local.cjs"
      }
    },
    "./xss": {
      "import": {
        "types": "./dist/xss/index.d.mts",
        "default": "./dist/xss/index.mjs"
      },
      "require": {
        "types": "./dist/xss/index.d.cts",
        "default": "./dist/xss/index.cjs"
      }
    },
    "./decimal": {
      "import": {
        "types": "./dist/decimal/index.d.mts",
        "default": "./dist/decimal/index.mjs"
      },
      "require": {
        "types": "./dist/decimal/index.d.cts",
        "default": "./dist/decimal/index.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "save-file",
    "date"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && komekko",
    "build:debug": "DEBUG=komekko:* pnpm clean && komekko"
  },
  "dependencies": {
    "@kazura/common": "^0.0.1",
    "@kazura/validator": "0.0.1",
    "@types/big.js": "^6.2.2",
    "@types/file-saver": "^2.0.7",
    "big.js": "^7.0.1",
    "copy-to-clipboard": "^3.3.3",
    "dayjs": "^1.11.18",
    "dompurify": "^3.2.7",
    "file-saver": "^2.0.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "komekko": "workspace:*",
    "rimraf": "^6.0.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2"
  },
  "npmName": "@kazura/web-util",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22.20.0"
  }
}